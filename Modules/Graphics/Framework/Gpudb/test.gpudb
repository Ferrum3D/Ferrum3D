import Meshlets
{
	cpp <Graphics/Core/Meshlet.h>
	hlsl <Shaders/Core/Meshlet.hlsli>
}

table MeshLodInfoTable
	: Meshlets
{
    Core::MeshLodInfo m_info;
}

table MeshGroupTable
{
    BufferPointer m_geometry;
	DB::Slice<MeshLodInfoTable> m_lods;
}

table MeshInstanceTable
{
	DB::Ref<MeshGroupTable> m_meshGroup;
	float4x4 m_transform;
}
